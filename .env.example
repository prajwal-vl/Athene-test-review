# ============================================================
# Athene AI — Environment Variables
# Copy this file to .env.local and fill in your values.
# ============================================================

# ── Clerk Auth (required) ─────────────────────────────────────
# https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/chat
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/chat
NEXT_PUBLIC_CLERK_AFTER_SIGN_OUT_URL=/

# ── Supabase (required) ───────────────────────────────────────
# https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# ── LLM (at least one required) ──────────────────────────────
DEEPSEEK_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...

# ── Encryption / BYOK (required) ─────────────────────────────
# Generate with: openssl rand -hex 32
ENCRYPTION_SECRET=
KMS_SECRET=

# ── App URL ───────────────────────────────────────────────────
# Production: set to your Vercel URL or custom domain.
# On Vercel, VERCEL_URL is used automatically if this is blank.
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ── Upstash Redis (required) ──────────────────────────────────
# https://console.upstash.com → Create Database → REST API
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# ── QStash (required for background workers) ──────────────────
# https://console.upstash.com → QStash
QSTASH_TOKEN=...
QSTASH_CURRENT_SIGNING_KEY=sig_...
QSTASH_NEXT_SIGNING_KEY=sig_...

# ── Nango (required for integrations) ────────────────────────
# https://app.nango.dev → Project Settings
NANGO_SECRET_KEY=...
NEXT_PUBLIC_NANGO_PUBLIC_KEY=...
